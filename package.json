{
  "name": "archmap",
  "version": "1.3.0",
  "description": "Architecture-as-Code for AI Agents. Scan your codebase, generate machine-readable architecture maps.",
  "type": "module",
  "bin": {
    "archmap": "./dist/bin/archmap.js",
    "archmap-mcp": "./dist/bin/archmap-mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/archmap.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "architecture",
    "ai",
    "agent",
    "claude",
    "codex",
    "mcp",
    "model-context-protocol",
    "python",
    "ci",
    "static-analysis",
    "dependency-graph",
    "codebase",
    "tree-sitter"
  ],
  "author": "matiasxth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matiasxth/archmap"
  },
  "homepage": "https://github.com/matiasxth/archmap#readme",
  "bugs": {
    "url": "https://github.com/matiasxth/archmap/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ora": "^8.2.0",
    "react": "^19.2.5",
    "simple-git": "^3.27.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7",
    "yaml": "^2.8.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
